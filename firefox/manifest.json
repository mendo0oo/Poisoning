{
  "manifest_version": 2,
  "name": "Poison Identity",
  "description": "A privacy extension that blocks trackers, spoofs fingerprint signals, and adds noise to protect anonymity.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "privacy",
    "cookies",
    "browsingData",
    "alarms",
    "tabs",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo-poison.png",
      "32": "logo-poison.png",
      "64": "logo-poison.png",
      "128": "logo-poison.png"
    }
  },
  "icons": {
    "16": "logo-poison.png",
    "32": "logo-poison.png",
    "64": "logo-poison.png",
    "128": "logo-poison.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    "pageScript.js"
  ],
  "applications": {
    "gecko": {
      "id": "poison-identity@example.com",
      "strict_min_version": "109.0"
    }
  }
}
